# --- MySQL ---
MYSQL_ROOT_PASSWORD=bitte_aendern_root
MYSQL_DATABASE=mailrelay
MYSQL_USER=mailrelay
MYSQL_PASSWORD=bitte_aendern_db

# --- Vorgelagerter Smarthost (z.B. Exchange/M365/Provider) ---
SMARTHOST=mail.example.com
SMARTHOST_PORT=587
SMARTHOST_USER=relay@example.com
SMARTHOST_PASSWORD=bitte_aendern_smarthost

# --- Postfix ---
MAIL_DOMAIN=example.com
# FQDN, den Postfix in SMTP-HELOs und Message-IDs verwendet.
POSTFIX_FQDN=relay.example.com
# Host-Ports: der Container verwendet weiterhin intern 25 und 587.
SMTP_PORT=25
SUBMISSION_PORT=587
# Veröffentlicht die WebGUI extern; intern bleibt sie auf Port 8080.
WEBGUI_PORT=8080
# Erlaubte Client-Netze, die OHNE SASL-Auth relayen duerfen (i.d.R. leer lassen,
# dann muss jeder Client per User/Passwort authentifizieren)
MYNETWORKS=127.0.0.0/8

# --- WebGUI ---
ADMIN_USER=admin
ADMIN_PASSWORD=bitte_aendern_admin
SECRET_KEY=bitte_langen_zufallsstring_eintragen
